# Update this to match your MySQL connection details
DATABASE_URL="mysql://root:password@localhost:3306/todolist"

# Optional (comma-separated list of allowed origins for CORS)
# Default: http://localhost:3000
CORS_ORIGINS="http://localhost:3000"

# Rate limiting (values are in milliseconds or counts)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Route-specific limits
RATE_LIMIT_CREATE_TODO_WINDOW_MS=900000
RATE_LIMIT_CREATE_TODO_MAX=20
RATE_LIMIT_MUTATION_WINDOW_MS=900000
RATE_LIMIT_MUTATION_MAX=50
